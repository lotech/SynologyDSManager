<?xml version="1.0" encoding="UTF-8"?>
<!--
    LaunchAgent plist bundled inside the main app at

        SynologyDSManager.app/Contents/Library/LaunchAgents/
            com.skavans.synologyDSManager.bridge.plist

    Phase 3b-2a: registered programmatically at first launch via
    `SMAppService.agent(plistName:).register()` from `AppDelegate`.

    Role
    ----
    Advertises the `com.skavans.synologyDSManager.bridge` Mach service
    name to launchd. Once registered, the sandboxed Safari Web
    Extension can open an `NSXPCConnection(machServiceName:)` to the
    main app. `SynologyBridgeListener` in the main target binds to
    the same name via `NSXPCListener(machServiceName:)`.

    BundleProgram, not Program
    --------------------------
    launchd requires SOME form of program key even when the agent
    is really doing `bootstrap_check_in`-style Mach service hosting.
    `BundleProgram` is the `SMAppService`-aware variant: the path
    resolves relative to the containing app bundle, so the agent
    works regardless of where the user installed the app
    (`/Applications`, `~/Applications`, etc.).

    Side effect: if the main app isn't running when a peer connects
    to the Mach name, launchd will spawn it via this path. That's
    actually the desired UX — right-click → download → app launches
    → download queued. The Safari Web Extension would otherwise
    fail silently when the app is closed, which is what the legacy
    `Webserver.swift` path does today.

    `LimitLoadToSessionType = Aqua` keeps the agent confined to GUI
    login sessions; it won't load in SSH / background contexts.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.skavans.synologyDSManager.bridge</string>

	<key>BundleProgram</key>
	<string>Contents/MacOS/SynologyDSManager</string>

	<key>MachServices</key>
	<dict>
		<key>com.skavans.synologyDSManager.bridge</key>
		<true/>
	</dict>

	<key>LimitLoadToSessionType</key>
	<string>Aqua</string>
</dict>
</plist>
