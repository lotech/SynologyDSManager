// Signing.xcconfig
//
// Global signing configuration for SynologyDSManager.
//
// - Committed to the public repo: this file, with no Team ID.
// - Gitignored: `Signing.local.xcconfig`, which you create from
//   `Signing.local.xcconfig.template` and fill in with *your* Apple Developer
//   Team ID. That way your Team ID never ends up in this public repository.
//
// The `#include?` directive below silently includes Signing.local.xcconfig if
// it exists, which is how the local override is applied. If you haven't set
// one up yet, signing will fall back to the (empty) defaults and Xcode will
// ask you to pick a team in Signing & Capabilities.
//
// For distribution builds (Release), we expect a
// "Developer ID Application" certificate in your login keychain. Create one
// in Xcode → Settings → Accounts → Manage Certificates → "+" → Developer ID
// Application. This is the cert that lets you notarise and distribute outside
// the Mac App Store.

// ----- Defaults -----

// Signing style is split per-configuration:
//
//   Debug   → Automatic. Xcode manages the profile against your Apple
//             Development cert and whatever team ID is set in
//             Signing.local.xcconfig. Works out of the box as long as
//             you're signed into your Apple ID in Xcode.
//
//   Release → Manual. Developer ID Application is a distribution cert
//             and is *not* managed by Xcode's automatic signing flow;
//             combining Automatic + Developer ID produces the warning:
//               "… is automatically signed for development, but a
//                conflicting code signing identity Developer ID
//                Application has been manually specified."
//             Switching Release to Manual signing fixes the warning
//             and matches how Developer-ID Mac apps are normally
//             distributed (outside the App Store, notarised via
//             notarytool, no provisioning profile required).
CODE_SIGN_STYLE = Automatic
CODE_SIGN_STYLE[config=Release] = Manual

// Debug/dev builds: use a local Apple Development cert.
CODE_SIGN_IDENTITY[sdk=macosx*][config=Debug] = Apple Development

// Distribution builds: use a Developer ID Application cert.
CODE_SIGN_IDENTITY[sdk=macosx*][config=Release] = Developer ID Application

// Empty placeholder — override in Signing.local.xcconfig.
DEVELOPMENT_TEAM =

// ----- Local override (gitignored) -----

#include? "Signing.local.xcconfig"
